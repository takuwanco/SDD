# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AWS Credentials (for Bedrock)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-northeast-1

# spec-ai-writer Settings
DEFAULT_LLM_PROVIDER=claude  # Options: claude, openai, bedrock
OUTPUT_DIR=./spec_output
AUTO_GIT_COMMIT=true
TEMPERATURE=0.7

# Optional: Project name prefix
PROJECT_NAME_PREFIX=my-project

# Application environment
APP_ENV=development # Options: development, production
