# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI-compatible endpoint overrides
# Leave OPENAI_BASE_URL empty for the official OpenAI API.
# Examples:
#   OpenRouter:  https://openrouter.ai/api/v1
#   Ollama:      http://localhost:11434/v1
#   LM Studio:   http://localhost:1234/v1
# When OPENAI_BASE_URL points at a local server, OPENAI_API_KEY may be left
# empty (a dummy value is substituted automatically).
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4-turbo-preview

# AWS Credentials (for Bedrock)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-northeast-1

# spec-ai-writer Settings
DEFAULT_LLM_PROVIDER=claude  # Options: claude, openai, bedrock
DATA_DIR=./data
AUTO_GIT_COMMIT=true
TEMPERATURE=0.7

# Application environment (development or production)
APP_ENV=development
